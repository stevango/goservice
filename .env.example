# =========================================================================
# Exemplo de variáveis de ambiente. Copie para um arquivo chamado `.env`
# (que NÃO é versionado) e preencha com os valores reais.
#
#   cp .env.example .env
#
# NUNCA coloque valores reais neste arquivo (.env.example é público).
# =========================================================================

# Ambiente: "development" (local) ou "production" (no servidor real)
NODE_ENV=development

# Porta do servidor (opcional, padrão 3000)
PORT=3000

# -------------------------------------------------------------------------
# Banco de dados (TiDB Cloud / MySQL). Pegue a string de conexão NOVA no
# painel do TiDB depois de rotacionar a senha.
# -------------------------------------------------------------------------
DATABASE_URL=mysql://USUARIO:SENHA@HOST:4000/BANCO?ssl={"rejectUnauthorized":true}

# -------------------------------------------------------------------------
# Segredo de sessão (assina o cookie de login). Mínimo 32 caracteres.
# Gere com:  openssl rand -base64 48
# -------------------------------------------------------------------------
JWT_SECRET=

# -------------------------------------------------------------------------
# Chave de criptografia de dados sensíveis (LGPD): conta bancária, PIX,
# CPF/RG. 32 bytes em base64. Gere com:  openssl rand -base64 32
# GUARDE COM SEGURANÇA: se perder, os dados cifrados ficam irrecuperáveis.
# -------------------------------------------------------------------------
FIELD_ENCRYPTION_KEY=

# -------------------------------------------------------------------------
# Autenticação Manus / OAuth
# -------------------------------------------------------------------------
OAUTH_SERVER_URL=https://api.manus.im
OWNER_OPEN_ID=
VITE_APP_ID=

# -------------------------------------------------------------------------
# Storage (Forge). Rotacione e preencha com as chaves novas.
# -------------------------------------------------------------------------
BUILT_IN_FORGE_API_URL=https://forge.manus.ai
BUILT_IN_FORGE_API_KEY=

# -------------------------------------------------------------------------
# Frontend (variáveis VITE_ são embutidas no build do navegador)
# -------------------------------------------------------------------------
VITE_APP_TITLE=Rede de Oficinas Brasil
VITE_APP_LOGO=
VITE_OAUTH_PORTAL_URL=https://manus.im
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.ai
VITE_FRONTEND_FORGE_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
